# Production Environment Variables
# Copy this file to .env.production and update with your production values

# MongoDB Atlas Connection String
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/silver-glow?retryWrites=true&w=majority

# JWT Secret (Generate a strong random key)
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long

# Frontend URL
FRONTEND_URL=https://silverglow.store

# Cookie Configuration
COOKIE_DOMAIN=.silverglow.store
USE_HTTPS=true
COOKIE_HTTP_ONLY=true

# Server Configuration
PORT=3131
NODE_ENV=production

# Default Admin User
DEFAULT_ADMIN_EMAIL=admin@silverglow.store
DEFAULT_ADMIN_PASSWORD=change-this-strong-password
DEFAULT_ADMIN_PHONE=201018939831
DEFAULT_ADMIN_ADDRESS=Your Address
DEFAULT_ADMIN_NAME=Super Admin

# Google API
GOOGLE_API_KEY=your-production-google-api-key

# WhatsApp API (Wasel)
WASEL_API_TOKEN=your-production-wasel-api-token
WASEL_INSTANCE_ID=your-production-instance-id
